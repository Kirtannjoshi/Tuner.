<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Tuner.Splash" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">#000000</item>
        <!-- Use windowSplashScreenAnimatedIcon to add a custom icon -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- Set the theme of the Activity that follows your splash screen -->
        <item name="postSplashScreenTheme">@style/Theme.Tuner</item>
    </style>

    <style name="Theme.Tuner" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#FF121212</item>
        <item name="android:statusBarColor">#FF121212</item>
        <item name="android:navigationBarColor">#FF121212</item>
    </style>
</resources>
